# PostgreSQL Database URL
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/ecofone?schema=public"

# JWT Config
JWT_SECRET="ecofone_jwt_super_secret_key"

# Cloudflare R2 Credentials (S3 Compatible API)
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="ecofone-bucket"
R2_PUBLIC_DOMAIN="https://pub-yourdomain.r2.dev"
